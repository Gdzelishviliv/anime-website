# ============================================================
# Anime Streaming Platform - Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values
# All services connect to localhost
# ============================================================

# ---- General ----
NODE_ENV=development

# ---- PostgreSQL (single local instance, multiple databases) ----
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- RabbitMQ ----
RABBITMQ_URL=amqp://localhost:5672

# ---- MinIO ----
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=anime-streams
MINIO_USE_SSL=false

# ---- JWT ----
JWT_SECRET=change-this-to-a-strong-random-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-another-strong-random-secret
JWT_REFRESH_EXPIRES_IN=7d

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000

# ---- External APIs ----
SIGNED_URL_SECRET=signed-url-secret-change-in-production
SIGNED_URL_EXPIRY=300

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_STREAM_URL=http://localhost:3004
